<section id="home" class="train-hero">
    <div class="train-hero-inner">
        <div class="hero-text">
            <h1>hi! i'm morgan!</h1>
            <h2>student / developer / writer</h2>
            <h3>
                <i>
                    short on time? view my resume
                    <a
                        href="/assets/morgan-guinyard-resume.pdf"
                        target="_blank"
                        rel="nofollow noopener noreferrer"
                    >
                        here
                    </a>
                </i>.
            </h3>
        </div>

        <div class="hero-image">
            <picture class="hero-picture">
                <img
                    src="/assets/morgan-hero-800.jpg"
                    srcset="/assets/morgan-hero-320.jpg 320w, /assets/morgan-hero-480.jpg 480w, /assets/morgan-hero-800.jpg 800w"
                    sizes="(max-width: 768px) 68vw, 400px"
                    width="800"
                    height="1067"
                    decoding="async"
                    fetchpriority="high"
                    alt="An image of Morgan Guinyard. She is standing in front of a snow-covered panther statue on Georgia State University's campus."
                />
            </picture>
        </div>
    </div>
</section>

<section id="about" class="info-section">
    <h2>about me</h2>
    <p>
        i'm a cs student at georgia state who likes building software that actually feels good to use.
        when i'm not coding or writing, i'm hiking, cooking, or exploring atlanta one bike lane at a time.
        i am a lifelong falcons fan (derogatory).
    </p>
</section>

