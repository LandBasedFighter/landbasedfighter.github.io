---
layout: base.njk
---

<article class="info-section post-article">
    <p><a href="/blog/">← all takes</a></p>
    <h1>{{ title }}</h1>
    <p class="post-meta">
        <time datetime="{{ page.date | htmlDate }}">{{ page.date | readableDate }}</time>
    </p>
    {% if heroImage %}
    <figure class="post-hero-image">
        <img src="{{ heroImage }}" alt="{{ heroImageAlt }}" loading="eager" decoding="async" />
        {% if heroImageCaption %}
        <figcaption>{{ heroImageCaption }}</figcaption>
        {% endif %}
    </figure>
    {% endif %}
    <div class="post-body">
        {{ content | safe }}
    </div>
</article>
